# Application
APP_NAME=Savdogar
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite+aiosqlite:///./savdogar.db

# SAYR integratsiya (tashqi tur platforma)
SAYR_API_URL=http://localhost:8001
SAYR_API_KEY=
SAYR_WEBHOOK_SECRET=your-webhook-secret
SAVDOGAR_PUBLIC_URL=https://savdogar-api-production.up.railway.app

# CORS
CORS_ORIGINS=http://localhost:3000,https://savdogar-sable.vercel.app,https://savdogar-five.vercel.app,https://savdogar-agentligi.vercel.app

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@sayr.uz

# Socket
SOCKET_CORS_ORIGINS=http://localhost:3000,https://savdogar-sable.vercel.app,https://savdogar-five.vercel.app,https://savdogar-agentligi.vercel.app
